# ==========================================
# QUDO 환경변수 템플릿 (Ubuntu / Oracle Cloud 같은 호스트 배포용)
# 사용법: cp .env.example .env 후 값 교체
#
# 네트워크 전략:
#   - API 컨테이너와 DB/Redis 컨테이너가 같은 docker network(qudo-net)에 있으므로
#     API는 호스트명 대신 컨테이너명으로 접근합니다.
#   - 호스트에서 직접 접근할 때는 127.0.0.1 + 외부 포트(5433/6380) 사용.
# ==========================================

# ---- Docker 이미지 (GHCR) ----
# GitHub Actions이 빌드해서 GHCR에 push → 서버는 이 경로에서 pull
# GitHub 계정(또는 조직)명을 소문자로 ${{ github.repository_owner }}
DOCKER_IMAGE=ghcr.io/<your-github-username>/qudo-api:latest

# ---- App ----
NODE_ENV=production
PORT=8080
TZ=Asia/Seoul

# ---- PostgreSQL (API 컨테이너 내부에서 본 값) ----
POSTGRES_HOST=qudo-postgres
POSTGRES_PORT=5432
POSTGRES_DB=qudo
POSTGRES_USER=qudo
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgres://qudo:change-me-strong@qudo-postgres:5432/qudo

# ---- Redis ----
REDIS_HOST=qudo-redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong
REDIS_URL=redis://:change-me-strong@qudo-redis:6379

# ---- Cloudflare R2 (S3 호환) ----
# CF 대시보드 > R2 > Overview 의 Account ID 확인
# CF 대시보드 > R2 > Manage API Tokens 에서 Access Key 발급
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=qudo-assets
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key
S3_FORCE_PATH_STYLE=true
# (선택) 공개 액세스 URL: R2 > 버킷 > Settings > Public Access 에서 설정
# 또는 커스텀 도메인: R2 > 버킷 > Settings > Custom Domains
S3_PUBLIC_URL=https://cdn.yourdomain.com

# ---- JWT ----
JWT_ACCESS_SECRET=generate-strong-secret
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# ---- Gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- OAuth ----
KAKAO_CLIENT_ID=
NAVER_CLIENT_ID=
GOOGLE_CLIENT_ID=
APPLE_TEAM_ID=
