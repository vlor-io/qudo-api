# ==========================================
# 배포 스크립트용 설정 (로컬 전용, git 에 올라가지 않음)
# 사용법: cp .deploy.env.example .deploy.env  후 값 교체
# ==========================================

# ---- 오라클 인스턴스 SSH ----
SSH_HOST=123.45.67.89              # 오라클 인스턴스 공인 IP
SSH_USER=ubuntu                    # SSH 유저 (오라클 기본 이미지는 ubuntu)
# SSH_KEY=~/.ssh/id_ed25519        # (선택) SSH 키 경로. 기본 키 쓰면 주석 유지

# ---- GHCR (Docker 이미지 pull용) ----
GHCR_USER=your-github-username     # GitHub 유저명 (소문자)
GHCR_PAT=ghp_xxxxxxxxxxxxxxxxxxxx  # read:packages 스코프의 Personal Access Token
